# AWS region
AWS_DEFAULT_REGION=eu-south-1

# Lambda function name
FUNCTION_NAME=claude-youtube-transcript

# IAM role name for Lambda execution
LAMBDA_ROLE_NAME=claude-youtube-transcript-exec

# S3 bucket for Lambda deployment packages (auto-computed if empty: <FUNCTION_NAME>-deploy-<account-id>)
DEPLOY_BUCKET=

# Lambda memory in MB (default: 256)
LAMBDA_MEMORY=256

# Access token TTL in days (default: 30)
TOKEN_TTL_DAYS=

# Webshare residential proxy for youtube-transcript-api (leave empty to disable)
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=
